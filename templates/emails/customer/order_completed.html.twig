{# emails/customer/order_completed.html.twig #}
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <style>
        body {
            font-family: Arial, Helvetica, sans-serif;
            line-height: 1.6;
            color: #000000;
            margin: 0;
            padding: 0;
            background-color: #ffffff;
        }
        .email-container {
            max-width: 600px;
            margin: 0 auto;
            padding: 40px 20px;
        }
        .email-content {
            font-size: 14px;
            line-height: 1.8;
        }
        .email-content p {
            margin: 0 0 16px 0;
        }
        a {
            color: #1a73e8;
            text-decoration: none;
        }
        a:hover {
            text-decoration: underline;
        }
        .signature {
            margin-top: 24px;
        }
    </style>
</head>
<body>
    <div class="email-container">
        <div class="email-content">
            <p>Dear {{ user.fullName }},</p>

            <p>We are pleased to hear that your complete Deckard order #{{ order.orderNumber }} has been delivered successfully!</p>

            <p>If you have any feedback on your experience, we would love to hear from you. You can reply to this email or leave a review through your account.</p>

            <p>You can view your order details here: <a href="{{ base_url }}/orders/{{ order.id }}">Link to Order Details</a></p>

            <p>We look forward to serving you again in the future.</p>

            <div class="signature">
                <p>Sincerely, The Deckard Team</p>
            </div>
        </div>
    </div>
</body>
</html>
