{% extends 'emails/base_email.html.twig' %}

{% block title %}Offer Sent - Inquiry #{{ inquiry.inquiryNumber }}{% endblock %}

{% block header %}Offer Sent{% endblock %}

{% block content %}
    <p>Hello Admin,</p>

    <p>Offer <strong class="highlight">{{ offer.offerNumber }}</strong> has been successfully sent to the client for inquiry <strong>#{{ inquiry.inquiryNumber }}</strong>.</p>

    <div class="alert alert-success">
        Inquiry status has been automatically updated to <strong>Completed</strong>.
    </div>

    <h3>Offer Details</h3>
    <table>
        <tr>
            <th>Offer Number</th>
            <td>{{ offer.offerNumber }}</td>
        </tr>
        <tr>
            <th>Inquiry Number</th>
            <td>{{ inquiry.inquiryNumber }}</td>
        </tr>
        <tr>
            <th>Items</th>
            <td>{{ offer.itemCount }} part(s)</td>
        </tr>
        <tr>
            <th>Total Amount</th>
            <td>&euro; {{ offer.totalAmount|number_format(2, '.', ',') }}</td>
        </tr>
        <tr>
            <th>Sent At</th>
            <td>{{ "now"|date('d.m.Y H:i') }}</td>
        </tr>
    </table>
{% endblock %}

{% block cta %}
    <div style="text-align: center; margin: 30px 0;">
        <a href="{{ viewUrl }}" class="btn" style="color: #ffffff;">View Inquiry</a>
    </div>
{% endblock %}

{% block footer %}
    <p>This is an automated notification from the Deckard Inquiry System.</p>
    <p>&copy; {{ "now"|date('Y') }} Deckard. All rights reserved.</p>
{% endblock %}
