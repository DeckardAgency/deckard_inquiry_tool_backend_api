{# emails/customer/order_confirmed.html.twig #}
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <style>
        body {
            font-family: Arial, Helvetica, sans-serif;
            line-height: 1.6;
            color: #000000;
            margin: 0;
            padding: 0;
            background-color: #ffffff;
        }
        .email-container {
            max-width: 600px;
            margin: 0 auto;
            padding: 40px 20px;
        }
        .email-content {
            font-size: 14px;
            line-height: 1.8;
        }
        .email-content p {
            margin: 0 0 16px 0;
        }
        .order-info {
            margin: 20px 0;
            padding: 0;
        }
        .order-info p {
            margin: 8px 0;
        }
        a {
            color: #1a73e8;
            text-decoration: none;
        }
        a:hover {
            text-decoration: underline;
        }
        .signature {
            margin-top: 24px;
        }
    </style>
</head>
<body>
    <div class="email-container">
        <div class="email-content">
            <p>Dear {{ user.fullName }},</p>

            <p>We are pleased to confirm your order #{{ order.orderNumber }}. Your request has been successfully processed and is now moving to the next stage.</p>

            <div class="order-info">
                <p><strong>Order ID:</strong> {{ order.orderNumber }}</p>
                <p><strong>Confirmation Date:</strong> {{ order.updatedAt|date('d M Y, H:i') }}</p>
                <p><strong>Items Ordered:</strong></p>
                {% for item in order.items %}
                <p style="margin-left: 20px;">• {{ item.product.name }} - Quantity: {{ item.quantity }}{% if item.unitPrice > 0 %} - €{{ item.unitPrice|number_format(2) }}{% endif %}</p>
                {% endfor %}
            </div>

            <p>You can view the full order details here: <a href="{{ base_url }}/orders/{{ order.id }}">Link to Order Details</a></p>

            <p>We will notify you of any further updates regarding the processing and shipment of your order.</p>

            <div class="signature">
                <p>Thank you for your order.</p>
                <p>Sincerely, The Deckard Team</p>
            </div>
        </div>
    </div>
</body>
</html>
