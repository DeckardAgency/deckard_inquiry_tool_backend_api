{# emails/customer/order_canceled.html.twig #}
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <style>
        body {
            font-family: Arial, Helvetica, sans-serif;
            line-height: 1.6;
            color: #000000;
            margin: 0;
            padding: 0;
            background-color: #ffffff;
        }
        .email-container {
            max-width: 600px;
            margin: 0 auto;
            padding: 40px 20px;
        }
        .email-content {
            font-size: 14px;
            line-height: 1.8;
        }
        .email-content p {
            margin: 0 0 16px 0;
        }
        a {
            color: #1a73e8;
            text-decoration: none;
        }
        a:hover {
            text-decoration: underline;
        }
        .signature {
            margin-top: 24px;
        }
    </style>
</head>
<body>
    <div class="email-container">
        <div class="email-content">
            <p>Dear {{ user.fullName }},</p>

            <p>This email confirms that your order #{{ order.orderNumber }} has been cancelled.</p>

            <p>If you cancelled this order yourself, no further action is required. If you did not initiate this cancellation, please contact our support team immediately at <a href="mailto:{{ supportEmail ?? 'support@deckard.com' }}">{{ supportEmail ?? 'support@deckard.com' }}</a>{% if supportPhone %} or {{ supportPhone }}{% endif %}.</p>

            <p>You can view your order details here: <a href="{{ base_url }}/orders/{{ order.id }}">Link to Order Details</a></p>

            <p>If you have any questions or would like to place a new order, please feel free to contact us.</p>

            <div class="signature">
                <p>Sincerely, The Deckard Team</p>
            </div>
        </div>
    </div>
</body>
</html>
