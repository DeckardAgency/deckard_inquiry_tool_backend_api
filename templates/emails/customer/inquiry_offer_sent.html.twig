{% extends 'emails/base_email.html.twig' %}

{% block title %}New Offer - Inquiry #{{ inquiry.inquiryNumber }}{% endblock %}

{% block header %}New Offer Available{% endblock %}

{% block content %}
    <p>Dear {{ user.firstName|default('Customer') }},</p>

    <p>A new offer has been prepared for your inquiry <strong class="highlight">#{{ inquiry.inquiryNumber }}</strong>.</p>

    <div class="alert alert-info">
        <strong>Offer {{ offer.offerNumber }}</strong> is ready for your review.
    </div>

    <h3>Offer Summary</h3>
    <table>
        <tr>
            <th>Offer Number</th>
            <td>{{ offer.offerNumber }}</td>
        </tr>
        <tr>
            <th>Items</th>
            <td>{{ offer.itemCount }} part(s)</td>
        </tr>
        <tr>
            <th>Total Amount</th>
            <td>&euro; {{ offer.totalAmount|number_format(2, '.', ',') }}</td>
        </tr>
    </table>

    {% if offer.notes %}
    <h3>Notes from Deckard</h3>
    <div style="background-color: #f8f9fa; padding: 15px; border-radius: 5px; border-left: 4px solid #007bff; margin: 15px 0;">
        {{ offer.notes|nl2br }}
    </div>
    {% endif %}

    <p>Please log in to your account to review the offer details and accept or decline:</p>
{% endblock %}

{% block cta %}
    <div style="text-align: center; margin: 30px 0;">
        <a href="{{ viewUrl }}" class="btn" style="color: #ffffff;">Review Offer</a>
    </div>
{% endblock %}

{% block footer %}
    <p>If you have any questions about this offer, please contact our sales team.</p>
    <p>&copy; {{ "now"|date('Y') }} Deckard. All rights reserved.</p>
{% endblock %}
