{% extends 'emails/base_email.html.twig' %}

{% block title %}Offer Rejected - Inquiry #{{ inquiry.inquiryNumber }}{% endblock %}

{% block header %}Offer Rejected{% endblock %}

{% block content %}
    <p>Hello Admin,</p>

    <p>The client has <strong style="color: #ef4444;">rejected</strong> offer <strong class="highlight">{{ offer.offerNumber }}</strong> for inquiry <strong>#{{ inquiry.inquiryNumber }}</strong>.</p>

    <div class="alert alert-danger">
        <strong>Client's Reason:</strong> {{ offer.rejectionReason|default('No reason provided') }}
    </div>

    <h3>Offer Details</h3>
    <table>
        <tr>
            <th>Offer Number</th>
            <td>{{ offer.offerNumber }}</td>
        </tr>
        <tr>
            <th>Inquiry Number</th>
            <td>{{ inquiry.inquiryNumber }}</td>
        </tr>
        <tr>
            <th>Items</th>
            <td>{{ offer.itemCount }} part(s)</td>
        </tr>
        <tr>
            <th>Total Amount</th>
            <td>&euro; {{ offer.totalAmount|number_format(2, '.', ',') }}</td>
        </tr>
        <tr>
            <th>Rejected At</th>
            <td>{{ offer.respondedAt|date('d.m.Y H:i') }}</td>
        </tr>
    </table>

    <p>You may create a new offer for this inquiry if needed.</p>
{% endblock %}

{% block cta %}
    <div style="text-align: center; margin: 30px 0;">
        <a href="{{ viewUrl }}" class="btn" style="color: #ffffff;">View Inquiry</a>
    </div>
{% endblock %}

{% block footer %}
    <p>This is an automated notification from the Deckard Inquiry System.</p>
    <p>&copy; {{ "now"|date('Y') }} Deckard. All rights reserved.</p>
{% endblock %}
