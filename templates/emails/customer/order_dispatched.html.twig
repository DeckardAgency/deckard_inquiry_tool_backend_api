{# emails/customer/order_dispatched.html.twig #}
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <style>
        body {
            font-family: Arial, Helvetica, sans-serif;
            line-height: 1.6;
            color: #000000;
            margin: 0;
            padding: 0;
            background-color: #ffffff;
        }
        .email-container {
            max-width: 600px;
            margin: 0 auto;
            padding: 40px 20px;
        }
        .email-content {
            font-size: 14px;
            line-height: 1.8;
        }
        .email-content p {
            margin: 0 0 16px 0;
        }
        .shipping-info {
            margin: 20px 0;
            padding: 0;
        }
        .shipping-info p {
            margin: 8px 0;
        }
        a {
            color: #1a73e8;
            text-decoration: none;
        }
        a:hover {
            text-decoration: underline;
        }
        .signature {
            margin-top: 24px;
        }
    </style>
</head>
<body>
    <div class="email-container">
        <div class="email-content">
            <p>Dear {{ user.fullName }},</p>

            <p>Good news! Your Deckard order #{{ order.orderNumber }} has been dispatched.</p>

            <div class="shipping-info">
                <p><strong>Here are the shipping details:</strong></p>
                <p><strong>Shipment reference number:</strong> {{ order.trackingNumber ?? '[Tracking Number]' }}</p>
                <p><strong>Shipping Carrier:</strong> {{ order.shippingCarrier ?? '[Shipping Carrier]' }}</p>
            </div>

            <p>You can also view your order details here: <a href="{{ base_url }}/orders/{{ order.id }}">Link to Order Details</a></p>

            <div class="signature">
                <p>Thank you for your order.</p>
                <p>Sincerely, The Deckard Team</p>
            </div>
        </div>
    </div>
</body>
</html>
